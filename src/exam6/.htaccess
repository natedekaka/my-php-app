# Prevent directory browsing
Options -Indexes

# Block access to SQL files
<FilesMatch "\.(sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to config files
<FilesMatch "\.(env|md|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP settings for large exams (many questions/students)
# Note: Some hosting providers may not allow these settings
<IfModule mod_php7.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 64M
    php_value max_input_vars 10000
    php_value max_execution_time 300
    php_value memory_limit 256M
</IfModule>
